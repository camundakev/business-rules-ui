<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_LeadProgramEvaluation" targetNamespace="http://camunda.org/schema/zeebe/nyl" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="lead-program-evaluation" name="Lead Program Evaluation" isExecutable="true">
    <bpmn:startEvent id="StartEvent_ReceiveAgent" name="Receive Agent">
      <bpmn:outgoing>Flow_Start_Eligibility</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="Task_EvaluateEligibility" name="Evaluate Eligibility">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="=eligibilityDecisionId" resultVariable="eligibilityResult" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Eligibility</bpmn:incoming>
      <bpmn:outgoing>Flow_Eligibility_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_Eligible" name="Eligible?" default="Flow_Eligible_No">
      <bpmn:incoming>Flow_Eligibility_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Eligible_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Eligible_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="Task_GenerateRecommendation" name="Generate Recommendation">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="=recommendationDecisionId" resultVariable="recommendations" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Eligible_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Recommendation_End</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:endEvent id="EndEvent_EligibleRecommendations" name="Eligible With Recommendations">
      <bpmn:incoming>Flow_13jwg5l</bpmn:incoming>
      <bpmn:incoming>Flow_016xjh7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:businessRuleTask id="Task_EvaluateUnenrollment" name="Evaluate Unenrollment">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="=unenrollmentDecisionId" resultVariable="unenrollmentResult" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Eligible_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Unenrollment_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_Unenroll" name="Unenroll?">
      <bpmn:incoming>Flow_Unenrollment_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Unenroll_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Unenroll_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_AutoUnenroll" name="Auto-Unenroll Agent">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="auto-unenroll-agent" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Unenroll_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoUnenroll_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_AgentUnenrolled" name="Agent Unenrolled">
      <bpmn:incoming>Flow_AutoUnenroll_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_HoldAgentStatus" name="Hold Agent Status">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="hold-agent-status" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Unenroll_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Hold_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_AgentOnHold" name="Agent On Hold">
      <bpmn:incoming>Flow_Hold_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Eligibility" sourceRef="StartEvent_ReceiveAgent" targetRef="Task_EvaluateEligibility" />
    <bpmn:sequenceFlow id="Flow_Eligibility_Gateway" sourceRef="Task_EvaluateEligibility" targetRef="Gateway_Eligible" />
    <bpmn:sequenceFlow id="Flow_Eligible_Yes" name="Yes" sourceRef="Gateway_Eligible" targetRef="Task_GenerateRecommendation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=eligibilityResult.isEligible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Eligible_No" name="No" sourceRef="Gateway_Eligible" targetRef="Task_EvaluateUnenrollment" />
    <bpmn:sequenceFlow id="Flow_Recommendation_End" sourceRef="Task_GenerateRecommendation" targetRef="Gateway_198q3mf" />
    <bpmn:sequenceFlow id="Flow_Unenrollment_Gateway" sourceRef="Task_EvaluateUnenrollment" targetRef="Gateway_Unenroll" />
    <bpmn:sequenceFlow id="Flow_Unenroll_Yes" name="Yes" sourceRef="Gateway_Unenroll" targetRef="Task_AutoUnenroll">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=unenrollmentResult.shouldUnenroll = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Unenroll_No" name="No" sourceRef="Gateway_Unenroll" targetRef="Task_HoldAgentStatus">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=unenrollmentResult.shouldUnenroll = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AutoUnenroll_End" sourceRef="Task_AutoUnenroll" targetRef="EndEvent_AgentUnenrolled" />
    <bpmn:sequenceFlow id="Flow_Hold_End" sourceRef="Task_HoldAgentStatus" targetRef="EndEvent_AgentOnHold" />
    <bpmn:exclusiveGateway id="Gateway_198q3mf" name="Training Required?" default="Flow_13jwg5l">
      <bpmn:incoming>Flow_Recommendation_End</bpmn:incoming>
      <bpmn:outgoing>Flow_1f3a53z</bpmn:outgoing>
      <bpmn:outgoing>Flow_13jwg5l</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1f3a53z" name="yes" sourceRef="Gateway_198q3mf" targetRef="Activity_0ee1yws">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=some r in get or else(recommendations, []) satisfies r.recommendationType = "training"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0tfll3t" sourceRef="Activity_0ee1yws" targetRef="Gateway_008s6aa" />
    <bpmn:serviceTask id="Activity_0ee1yws" name="Send Training Email" zeebe:modelerTemplate="io.camunda.connectors.SendGrid.v2" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendgrid:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SENDGRID_KEY}}" target="apiKey" />
          <zeebe:input source="Camunda" target="from.name" />
          <zeebe:input source="demo@camunda.com" target="from.email" />
          <zeebe:input source="=agentName" target="to.name" />
          <zeebe:input source="=agentEmail" target="to.email" />
          <zeebe:input source="mail" target="unMappedFieldNotUseInModel.mailType" />
          <zeebe:input source="Lead Offer and Training" target="content.subject" />
          <zeebe:input source="text/plain" target="content.type" />
          <zeebe:input source="=&#34;Hello, &#34; + agentName + &#34;.\n\n&#34; + &#10;&#34;We are pleased to offer you a spot in our lead program. Our records indicate you will need to complete the following training.\n\n&#34; + &#10;&#34;Link to training: &#34; + recommendations[recommendationType = &#34;training&#34;][1].recommendationLink + &#10;&#34;\n\nThank you,\n&#34; + &#10;&#34;Camunda Inc.&#34;" target="content.value" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.SendGrid.v2" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1f3a53z</bpmn:incoming>
      <bpmn:outgoing>Flow_0tfll3t</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_13jwg5l" name="no" sourceRef="Gateway_198q3mf" targetRef="EndEvent_EligibleRecommendations" />
    <bpmn:endEvent id="Event_1az1tqs" name="Did Not Complete Training">
      <bpmn:incoming>Flow_1bx39oj</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="Event_1kyzdu3" name="30 Days">
      <bpmn:incoming>Flow_0hr6r57</bpmn:incoming>
      <bpmn:outgoing>Flow_1bx39oj</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_10gzsra">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P30D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_0hr6r57" sourceRef="Gateway_008s6aa" targetRef="Event_1kyzdu3" />
    <bpmn:eventBasedGateway id="Gateway_008s6aa">
      <bpmn:incoming>Flow_0tfll3t</bpmn:incoming>
      <bpmn:outgoing>Flow_0hr6r57</bpmn:outgoing>
      <bpmn:outgoing>Flow_08v0479</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="Flow_1bx39oj" sourceRef="Event_1kyzdu3" targetRef="Event_1az1tqs" />
    <bpmn:sequenceFlow id="Flow_08v0479" sourceRef="Gateway_008s6aa" targetRef="Event_1a83bmt" />
    <bpmn:sequenceFlow id="Flow_016xjh7" sourceRef="Event_1a83bmt" targetRef="EndEvent_EligibleRecommendations" />
    <bpmn:intermediateCatchEvent id="Event_1a83bmt" name="Training Complete" zeebe:modelerTemplate="io.camunda.connectors.webhook.WebhookConnectorIntermediate.v1" zeebe:modelerTemplateVersion="14" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="inbound.type" value="io.camunda:webhook:1" />
          <zeebe:property name="inbound.method" value="post" />
          <zeebe:property name="inbound.context" value="training-complete" />
          <zeebe:property name="inbound.shouldValidateHmac" value="disabled" />
          <zeebe:property name="inbound.auth.type" value="NONE" />
          <zeebe:property name="consumeUnmatchedEvents" value="true" />
          <zeebe:property name="synchronousResponse" value="false" />
          <zeebe:property name="correlationKeyExpression" value="=request.body.agentCode" />
          <zeebe:property name="deduplicationModeManualFlag" value="false" />
          <zeebe:property name="deduplicationMode" value="AUTO" />
          <zeebe:property name="resultVariable" />
          <zeebe:property name="resultExpression" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_08v0479</bpmn:incoming>
      <bpmn:outgoing>Flow_016xjh7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1yh6vyq" messageRef="Message_0fp3y3m" />
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmn:message id="Message_0fp3y3m" name="7e2638a0-1657-4ad3-89c6-5cdfa61ffa89" zeebe:modelerTemplate="io.camunda.connectors.webhook.WebhookConnectorIntermediate.v1">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=agentCode" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmndi:BPMNDiagram id="BPMNDiagram_LeadProgramEvaluation">
    <bpmndi:BPMNPlane id="BPMNPlane_LeadProgramEvaluation" bpmnElement="lead-program-evaluation">
