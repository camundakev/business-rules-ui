<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  id="Definitions_LeadProgramEvaluation"
                  targetNamespace="http://camunda.org/schema/zeebe/nyl"
                  exporter="Claude Code"
                  exporterVersion="1.0"
                  modeler:executionPlatform="Camunda Cloud"
                  modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="lead-program-evaluation" name="Lead Program Evaluation" isExecutable="true">

    <bpmn:startEvent id="StartEvent_ReceiveAgent" name="Receive Agent">
      <bpmn:outgoing>Flow_Start_Eligibility</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:businessRuleTask id="Task_EvaluateEligibility" name="Evaluate Eligibility">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="=eligibilityDecisionId" resultVariable="eligibilityResult"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Eligibility</bpmn:incoming>
      <bpmn:outgoing>Flow_Eligibility_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_Eligible" name="Eligible?">
      <bpmn:incoming>Flow_Eligibility_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Eligible_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Eligible_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:businessRuleTask id="Task_GenerateRecommendation" name="Generate Recommendation">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="=recommendationDecisionId" resultVariable="recommendations"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Eligible_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Recommendation_End</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:endEvent id="EndEvent_EligibleRecommendations" name="Eligible With Recommendations">
      <bpmn:incoming>Flow_Recommendation_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:businessRuleTask id="Task_EvaluateUnenrollment" name="Evaluate Unenrollment">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="=unenrollmentDecisionId" resultVariable="unenrollmentResult"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Eligible_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Unenrollment_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_Unenroll" name="Unenroll?">
      <bpmn:incoming>Flow_Unenrollment_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Unenroll_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Unenroll_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_AutoUnenroll" name="Auto-Unenroll Agent">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="auto-unenroll-agent" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Unenroll_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoUnenroll_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_AgentUnenrolled" name="Agent Unenrolled">
      <bpmn:incoming>Flow_AutoUnenroll_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="Task_HoldAgentStatus" name="Hold Agent Status">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="hold-agent-status" retries="3"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Unenroll_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Hold_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_AgentOnHold" name="Agent On Hold">
      <bpmn:incoming>Flow_Hold_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_Eligibility"
                       sourceRef="StartEvent_ReceiveAgent"
                       targetRef="Task_EvaluateEligibility"/>

    <bpmn:sequenceFlow id="Flow_Eligibility_Gateway"
                       sourceRef="Task_EvaluateEligibility"
                       targetRef="Gateway_Eligible"/>

    <bpmn:sequenceFlow id="Flow_Eligible_Yes" name="Yes"
                       sourceRef="Gateway_Eligible"
                       targetRef="Task_GenerateRecommendation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=eligibilityResult.isEligible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Eligible_No" name="No"
                       sourceRef="Gateway_Eligible"
                       targetRef="Task_EvaluateUnenrollment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=eligibilityResult.isEligible = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Recommendation_End"
                       sourceRef="Task_GenerateRecommendation"
                       targetRef="EndEvent_EligibleRecommendations"/>

    <bpmn:sequenceFlow id="Flow_Unenrollment_Gateway"
                       sourceRef="Task_EvaluateUnenrollment"
                       targetRef="Gateway_Unenroll"/>

    <bpmn:sequenceFlow id="Flow_Unenroll_Yes" name="Yes"
                       sourceRef="Gateway_Unenroll"
                       targetRef="Task_AutoUnenroll">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=unenrollmentResult.shouldUnenroll = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Unenroll_No" name="No"
                       sourceRef="Gateway_Unenroll"
                       targetRef="Task_HoldAgentStatus">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=unenrollmentResult.shouldUnenroll = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_AutoUnenroll_End"
                       sourceRef="Task_AutoUnenroll"
                       targetRef="EndEvent_AgentUnenrolled"/>

    <bpmn:sequenceFlow id="Flow_Hold_End"
                       sourceRef="Task_HoldAgentStatus"
                       targetRef="EndEvent_AgentOnHold"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_LeadProgramEvaluation">
    <bpmndi:BPMNPlane id="BPMNPlane_LeadProgramEvaluation" bpmnElement="lead-program-evaluation">

      <bpmndi:BPMNShape id="StartEvent_ReceiveAgent_di" bpmnElement="StartEvent_ReceiveAgent">
        <dc:Bounds x="160" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="148" y="245" width="62" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_EvaluateEligibility_di" bpmnElement="Task_EvaluateEligibility">
        <dc:Bounds x="260" y="180" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Eligible_di" bpmnElement="Gateway_Eligible" isMarkerVisible="true">
        <dc:Bounds x="445" y="195" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="447" y="172" width="46" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_GenerateRecommendation_di" bpmnElement="Task_GenerateRecommendation">
        <dc:Bounds x="580" y="60" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_EligibleRecommendations_di" bpmnElement="EndEvent_EligibleRecommendations">
        <dc:Bounds x="772" y="82" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="730" y="125" width="120" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_EvaluateUnenrollment_di" bpmnElement="Task_EvaluateUnenrollment">
        <dc:Bounds x="580" y="290" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Unenroll_di" bpmnElement="Gateway_Unenroll" isMarkerVisible="true">
        <dc:Bounds x="775" y="305" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="775" y="282" width="50" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_AutoUnenroll_di" bpmnElement="Task_AutoUnenroll">
        <dc:Bounds x="900" y="200" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_AgentUnenrolled_di" bpmnElement="EndEvent_AgentUnenrolled">
        <dc:Bounds x="1092" y="222" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1064" y="265" width="92" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_HoldAgentStatus_di" bpmnElement="Task_HoldAgentStatus">
        <dc:Bounds x="900" y="380" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_AgentOnHold_di" bpmnElement="EndEvent_AgentOnHold">
        <dc:Bounds x="1092" y="402" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1067" y="445" width="86" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_Eligibility_di" bpmnElement="Flow_Start_Eligibility">
        <di:waypoint x="196" y="220"/>
        <di:waypoint x="260" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Eligibility_Gateway_di" bpmnElement="Flow_Eligibility_Gateway">
        <di:waypoint x="380" y="220"/>
        <di:waypoint x="445" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Eligible_Yes_di" bpmnElement="Flow_Eligible_Yes">
        <di:waypoint x="470" y="195"/>
        <di:waypoint x="470" y="100"/>
        <di:waypoint x="580" y="100"/>
        <bpmndi:BPMNLabel><dc:Bounds x="478" y="145" width="20" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Recommendation_End_di" bpmnElement="Flow_Recommendation_End">
        <di:waypoint x="720" y="100"/>
        <di:waypoint x="772" y="100"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Eligible_No_di" bpmnElement="Flow_Eligible_No">
        <di:waypoint x="470" y="245"/>
        <di:waypoint x="470" y="330"/>
        <di:waypoint x="580" y="330"/>
        <bpmndi:BPMNLabel><dc:Bounds x="478" y="285" width="16" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Unenrollment_Gateway_di" bpmnElement="Flow_Unenrollment_Gateway">
        <di:waypoint x="720" y="330"/>
        <di:waypoint x="775" y="330"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Unenroll_Yes_di" bpmnElement="Flow_Unenroll_Yes">
        <di:waypoint x="800" y="305"/>
        <di:waypoint x="800" y="240"/>
        <di:waypoint x="900" y="240"/>
        <bpmndi:BPMNLabel><dc:Bounds x="808" y="265" width="20" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_AutoUnenroll_End_di" bpmnElement="Flow_AutoUnenroll_End">
        <di:waypoint x="1040" y="240"/>
        <di:waypoint x="1092" y="240"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Unenroll_No_di" bpmnElement="Flow_Unenroll_No">
        <di:waypoint x="800" y="355"/>
        <di:waypoint x="800" y="420"/>
        <di:waypoint x="900" y="420"/>
        <bpmndi:BPMNLabel><dc:Bounds x="808" y="375" width="16" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Hold_End_di" bpmnElement="Flow_Hold_End">
        <di:waypoint x="1040" y="420"/>
        <di:waypoint x="1092" y="420"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
