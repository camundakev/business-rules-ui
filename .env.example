# Camunda SaaS cluster connection
# (Used by @camunda8/sdk in workers/ and by the Vite proxy for frontend/)

# Cluster identity
CAMUNDA_CLUSTER_ID=<your-cluster-id>
CAMUNDA_CLUSTER_REGION=<region-e.g.-jfk-1>

# OAuth client credentials (created in Camunda SaaS Console → Cluster → API)
CAMUNDA_CLIENT_ID=<your-client-id>
CAMUNDA_CLIENT_SECRET=<your-client-secret>
CAMUNDA_OAUTH_URL=https://login.cloud.camunda.io/oauth/token
CAMUNDA_CREDENTIALS_SCOPES=Orchestration
CAMUNDA_CLIENT_MODE=saas
CAMUNDA_TOKEN_AUDIENCE=zeebe.camunda.io

# REST + gRPC endpoints (derived from cluster id + region)
ZEEBE_REST_ADDRESS=https://<region>.api.camunda.io/<cluster-id>
ZEEBE_GRPC_ADDRESS=grpcs://<cluster-id>.<region>.zeebe.camunda.io:443
ZEEBE_AUTHORIZATION_SERVER_URL=https://login.cloud.camunda.io/oauth/token

# Frontend / dev server
PORT=3000
